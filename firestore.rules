rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('ADMIN') || hasRole('SUPER_ADMIN');
    }

    function ownsPharmacy(pharmacyId) {
      return hasRole('PHARMACY') &&
        request.auth.token.pharmacyId == pharmacyId;
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'status', 'claims', 'walletBalance']);
      allow delete: if false;

      match /addresses/{addressId} {
        allow read, create, update, delete: if request.auth.uid == userId;
      }

      match /devices/{deviceId} {
        allow read, create, update, delete: if request.auth.uid == userId;
      }
    }

    match /medicines/{medicineId} {
      allow read: if resource.data.status == 'ACTIVE' || isAdmin();
      allow write: if isAdmin();
    }

    match /medicineCategories/{categoryId} {
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }

    match /pharmacies/{pharmacyId} {
      allow read: if resource.data.verificationStatus == 'APPROVED' ||
        ownsPharmacy(pharmacyId) || isAdmin();
      allow create: if hasRole('PHARMACY') &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAdmin() || (
        ownsPharmacy(pharmacyId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['verificationStatus', 'status', 'commissionRate', 'ownerUid'])
      );
      allow delete: if false;

      match /inventory/{medicineId} {
        allow read: if ownsPharmacy(pharmacyId) || isAdmin();
        allow write: if ownsPharmacy(pharmacyId) || isAdmin();
      }
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.pharmacyId == request.auth.token.pharmacyId ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow write: if false;
    }

    match /drivers/{driverId} {
      allow read: if isAdmin() ||
        (signedIn() && request.auth.uid == driverId);
      allow write: if false;
    }

    match /pharmacyOrderRequests/{requestId} {
      allow read: if signedIn() && (
        resource.data.pharmacyId == request.auth.token.pharmacyId ||
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow write: if false;
    }

    match /prescriptions/{prescriptionId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.assignedPharmacyId == request.auth.token.pharmacyId ||
        isAdmin()
      );
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
