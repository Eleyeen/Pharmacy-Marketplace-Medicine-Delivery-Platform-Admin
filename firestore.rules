rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminRole() {
      return signedIn()
        && request.auth.token.role in ['admin', 'ADMIN', 'SUPER_ADMIN'];
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Privileged fields change only via Admin SDK (callable Cloud Functions).
    function pharmacyClientWritable() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['verificationStatus', 'status', 'rejectionReason', 'suspensionReason', 'approvedBy', 'rejectedBy', 'suspendedBy']));
    }

    function userClientWritable() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['status', 'role', 'blockReason']));
    }

    match /users/{userId} {
      allow read: if adminRole() || isOwner(userId);
      allow create: if adminRole() || isOwner(userId);
      allow update: if (adminRole() || isOwner(userId)) && userClientWritable();
      allow delete: if adminRole();

      match /addresses/{addressId} {
        allow read: if adminRole() || isOwner(userId);
        allow write: if adminRole() || isOwner(userId);
      }

      match /devices/{deviceId} {
        allow read, write: if adminRole() || isOwner(userId);
      }
    }

    match /pharmacies/{pharmacyId} {
      allow read: if adminRole()
        || (resource.data.verificationStatus == 'APPROVED' && resource.data.status == 'ACTIVE')
        || (signedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if adminRole()
        || (signedIn()
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.verificationStatus == 'PENDING'
          && request.resource.data.status == 'PENDING');
      allow update: if (adminRole() || (signedIn() && resource.data.ownerUid == request.auth.uid))
        && pharmacyClientWritable();
      allow delete: if adminRole();

      match /inventory/{medicineId} {
        allow read: if adminRole()
          || get(/databases/$(database)/documents/pharmacies/$(pharmacyId)).data.verificationStatus == 'APPROVED';
        allow write: if adminRole()
          || (signedIn()
            && get(/databases/$(database)/documents/pharmacies/$(pharmacyId)).data.ownerUid == request.auth.uid);
      }
    }

    match /orders/{orderId} {
      allow read: if adminRole()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (signedIn() && resource.data.pharmacyId != null
          && get(/databases/$(database)/documents/pharmacies/$(resource.data.pharmacyId)).data.ownerUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if adminRole()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /medicines/{medicineId} {
      allow read: if true;
      allow write: if adminRole();
    }

    match /medicineCategories/{categoryId} {
      allow read: if true;
      allow write: if adminRole();
    }

    match /reviews/{reviewId} {
      allow read: if adminRole()
        || resource.data.status == 'VISIBLE'
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if adminRole();
      allow write: if false;
    }
  }
}
